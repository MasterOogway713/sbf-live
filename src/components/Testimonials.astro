---
const testimonials = [
  {
    quote: "The most breathtaking arrangement I've ever received. The attention to detail and the quality of the stems is incomparable. Truly a luxury experience.",
    author: "Eleanor W.",
    location: "London"
  },
  {
    quote: "SB Floristry designed our wedding flowers and people are still talking about them. They captured our vision perfectly and were such a joy to work with.",
    author: "Sophia R.",
    location: "Essex"
  },
  {
    quote: "A beautiful family-run business. Their sympathy tributes were handled with such grace and kindness during a very difficult time for our family.",
    author: "James M.",
    location: "Romford"
  }
];
---

<section class="py-24 bg-white overflow-hidden">
    <div class="container mx-auto px-6">
        <div class="text-center mb-16 reveal">
            <span class="text-sb-gold text-xs tracking-[0.35em] uppercase font-bold mb-4 block">Kind Words</span>
            <h3 class="font-serif text-4xl md:text-5xl text-sb-black font-light italic">The SB Experience</h3>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
            {testimonials.map((t, idx) => (
                <div class="flex flex-col items-center text-center reveal" style={`transition-delay: ${idx * 150}ms`}>
                    <div class="mb-6">
                        <i class="fas fa-star text-sb-gold text-[10px]"></i>
                        <i class="fas fa-star text-sb-gold text-[10px]"></i>
                        <i class="fas fa-star text-sb-gold text-[10px]"></i>
                        <i class="fas fa-star text-sb-gold text-[10px]"></i>
                        <i class="fas fa-star text-sb-gold text-[10px]"></i>
                    </div>
                    <p class="text-gray-600 font-light italic leading-relaxed mb-8 text-lg">"{t.quote}"</p>
                    <div>
                        <span class="block font-serif text-xl text-sb-black">{t.author}</span>
                        <span class="block text-[10px] tracking-luxury uppercase text-gray-400 mt-1">{t.location}</span>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
