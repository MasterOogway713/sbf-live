---
const { product, isDarkTheme = false } = Astro.props;

const price = product.variants.edges[0]?.node?.price;
const priceAmount = price ? price.amount : '0.00';
const variantId = product.variants.edges[0]?.node?.id;
const priceText = price ? `£${parseFloat(price.amount).toFixed(2)}` : '£0.00';
const images = product.images.edges.map(e => e.node.url);
const img1 = images[0] || '/images/hero.jpg';
const img2 = images[1] || null;

const textClass = isDarkTheme ? "text-white" : "text-sb-black";
---

<div class="group relative">
    <div class="relative overflow-hidden mb-4 aspect-[4/5] bg-gray-100">
        <img src={img1} alt={product.title} class="w-full h-full object-cover transition-opacity duration-700" />
        {img2 && (
            <img src={img2} alt={product.title} class="absolute inset-0 w-full h-full object-cover opacity-0 group-hover:opacity-100 transition-opacity duration-700" />
        )}

        <button 
            class="add-to-cart-btn absolute bottom-0 left-0 w-full bg-white/90 text-sb-black py-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300 font-bold tracking-widest text-[10px] uppercase z-20"
            data-id={variantId}
            data-title={product.title}
            data-price={priceAmount}
            data-image={img1}
        >
            Add to Cart
        </button>
    </div>
    
    <h4 class={`font-serif text-2xl ${textClass} mb-1 font-light`}>{product.title}</h4>
    <p class="text-sb-gold font-medium">{priceText}</p>
</div>