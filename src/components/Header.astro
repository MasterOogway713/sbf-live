---
// src/components/Header.astro
---

<style>
    .bg-gold-shimmer {
        background: linear-gradient(90deg, #997b3a 0%, #b89546 25%, #D4AF37 50%, #b89546 75%, #997b3a 100%);
        background-size: 200% auto; 
        animation: subtleShimmer 8s linear infinite;
    }
    @keyframes subtleShimmer { 
        0% { background-position: 0% 50%; } 
        100% { background-position: 100% 50%; } 
    }
    .nav-dropdown {
        opacity: 0; visibility: hidden; transform: translateY(10px); transition: all 0.3s ease-in-out;
    }
    .group:hover .nav-dropdown {
        opacity: 1; visibility: visible; transform: translateY(0);
    }
</style>

<div class="bg-gold-shimmer text-sb-black text-[10px] py-2.5 px-4 text-center tracking-[0.25em] uppercase font-bold border-b border-sb-cream/20">
    <p>Family Run • Free delivery over £60 within a 3 mile radius • UK Standard £4.99</p>
</div>

<header class="sticky top-0 z-50 bg-sb-black/95 backdrop-blur-md transition-all duration-300 border-b border-white/5" id="mainHeader">
    <div class="container mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-[1fr_auto_1fr] items-center h-20 md:h-24">
            
            <div class="flex items-center justify-start lg:justify-end h-full">
                <button id="mobileMenuBtn" class="lg:hidden text-xl text-sb-cream focus:outline-none hover:text-sb-gold transition-colors mr-auto p-2">
                    <i class="fas fa-bars"></i>
                </button>
                <nav class="hidden lg:flex space-x-8 xl:space-x-10 text-[11px] font-medium tracking-luxury text-gray-300 uppercase items-center">
                    <a href="/" class="hover:text-sb-gold transition-colors duration-300">Home</a>
                    
                    <div class="relative group h-full flex items-center">
                        <button class="hover:text-sb-gold transition-colors duration-300 focus:outline-none py-4 uppercase tracking-luxury flex items-center gap-1">
                            Shop Collections <i class="fas fa-chevron-down text-[8px] opacity-50 ml-1"></i>
                        </button>
                        <div class="nav-dropdown absolute top-full left-0 w-48 bg-sb-black border border-white/10 shadow-2xl pt-2 pb-2">
                            <a href="/collections/signature" class="block px-6 py-3 hover:bg-white/5 hover:text-sb-gold text-[10px] tracking-luxury transition-colors">Signature</a>
                            <a href="/collections/seasonal" class="block px-6 py-3 hover:bg-white/5 hover:text-sb-gold text-[10px] tracking-luxury transition-colors">Seasonal</a>
                            <a href="/collections/sympathy" class="block px-6 py-3 hover:bg-white/5 hover:text-sb-gold text-[10px] tracking-luxury transition-colors">Sympathy</a>
                            <a href="/collections/weddings" class="block px-6 py-3 hover:bg-white/5 hover:text-sb-gold text-[10px] tracking-luxury transition-colors">Weddings</a>
                        </div>
                    </div>
                </nav>
            </div>

            <div class="flex justify-center h-full items-center px-8">
                <a href="/" class="group block text-center">
                    <img src="/images/logo.png" alt="SB Floristry" class="h-16 w-auto object-contain opacity-90 group-hover:opacity-100 transition-opacity">
                </a>
            </div>

            <div class="flex items-center justify-end lg:justify-between h-full w-full">
                <nav class="hidden lg:flex space-x-8 xl:space-x-10 text-[11px] font-medium tracking-luxury text-gray-300 uppercase items-center">
                    <div class="relative group h-full flex items-center">
                        <button class="hover:text-sb-gold transition-colors duration-300 focus:outline-none py-4 uppercase tracking-luxury flex items-center gap-1">
                            Events <i class="fas fa-chevron-down text-[8px] opacity-50 ml-1"></i>
                        </button>
                        <div class="nav-dropdown absolute top-full right-0 w-56 bg-sb-black border border-white/10 shadow-2xl pt-2 pb-2">
                            <a href="/weddings" class="block px-6 py-3 hover:bg-white/5 hover:text-sb-gold text-[10px] tracking-luxury transition-colors">Weddings</a>
                            <a href="/funerals" class="block px-6 py-3 hover:bg-white/5 hover:text-sb-gold text-[10px] tracking-luxury transition-colors">Funerals</a>
                            <a href="/babyshowers" class="block px-6 py-3 hover:bg-white/5 hover:text-sb-gold text-[10px] tracking-luxury transition-colors">Baby Showers</a>
                        </div>
                    </div>
                    <a href="/contact" class="hover:text-sb-gold transition-colors duration-300">Contact</a>
                </nav>

                <div class="flex items-center space-x-6 text-sb-cream/80">
                    <button id="cartBtn" class="relative hover:text-sb-gold transition-colors group p-1">
                        <i class="fas fa-shopping-bag text-sm"></i>
                        <span id="cartCount" class="absolute -top-2 -right-2 text-sb-gold font-bold font-serif text-xs w-5 h-5 flex items-center justify-center transition-opacity duration-300 bg-sb-black rounded-full border border-sb-gold hidden">0</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</header>

<!-- Mobile Menu -->
<div id="mobileMenu" class="fixed inset-0 bg-sb-black z-[100] transform -translate-x-full transition-transform duration-500 ease-in-out lg:hidden flex flex-col pt-20 px-8 overflow-y-auto">
    <button id="closeMenuBtn" class="absolute top-6 right-6 text-2xl text-sb-cream hover:text-sb-gold transition-colors p-2">
        <i class="fas fa-times"></i>
    </button>
    <nav class="flex flex-col mt-6">
        <a href="/" class="block w-full text-left text-sb-gold text-sm tracking-widest uppercase py-4 border-b border-white/5 hover:text-white transition-colors mobile-link">Home</a>
        
        <div>
            <button class="mobile-accordion-btn w-full flex justify-between items-center text-sb-gold text-sm tracking-widest uppercase py-4 border-b border-white/5 focus:outline-none hover:text-white transition-colors">
                Shop Collections <i class="fas fa-chevron-down text-xs transition-transform duration-300"></i>
            </button>
            <div class="mobile-accordion-content bg-white/5">
                <a href="/collections/signature" class="block py-3 pl-4 text-sm text-gray-300 hover:text-white mobile-link">Signature</a>
                <a href="/collections/seasonal" class="block py-3 pl-4 text-sm text-gray-300 hover:text-white mobile-link">Seasonal</a>
                <a href="/collections/sympathy" class="block py-3 pl-4 text-sm text-gray-300 hover:text-white mobile-link">Sympathy</a>
                <a href="/collections/weddings" class="block py-3 pl-4 text-sm text-gray-300 hover:text-white mobile-link">Weddings</a>
            </div>
        </div>

        <div>
            <button class="mobile-accordion-btn w-full flex justify-between items-center text-sb-gold text-sm tracking-widest uppercase py-4 border-b border-white/5 focus:outline-none hover:text-white transition-colors">
                Events <i class="fas fa-chevron-down text-xs transition-transform duration-300"></i>
            </button>
            <div class="mobile-accordion-content bg-white/5">
                <a href="/weddings" class="block py-3 pl-4 text-sm text-gray-300 hover:text-white mobile-link">Weddings</a>
                <a href="/funerals" class="block py-3 pl-4 text-sm text-gray-300 hover:text-white mobile-link">Funerals</a>
                <a href="/babyshowers" class="block py-3 pl-4 text-sm text-gray-300 hover:text-white mobile-link">Baby Showers</a>
            </div>
        </div>

        <a href="/contact" class="block w-full text-left text-sb-gold text-sm tracking-widest uppercase py-4 border-b border-white/5 hover:text-white transition-colors mobile-link">Contact</a>
    </nav>
</div>

<!-- Client-side script for the Mobile Menu -->
<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        const mobileMenuBtn = document.getElementById('mobileMenuBtn');
        const closeMenuBtn = document.getElementById('closeMenuBtn');
        const mobileMenu = document.getElementById('mobileMenu');
        const accordionBtns = document.querySelectorAll('.mobile-accordion-btn');

        // Toggle Mobile Menu
        function toggleMenu() {
            if (mobileMenu) {
                mobileMenu.classList.toggle('-translate-x-full');
                document.body.style.overflow = mobileMenu.classList.contains('-translate-x-full') ? 'hidden' : '';
            }
        }

        if (mobileMenuBtn) mobileMenuBtn.addEventListener('click', toggleMenu);
        if (closeMenuBtn) closeMenuBtn.addEventListener('click', toggleMenu);

        // Handle Mobile Accordions
        accordionBtns.forEach(btn => {
            btn.addEventListener('click', function() {
                this.classList.toggle('active');
            });
        });
    });
</script>