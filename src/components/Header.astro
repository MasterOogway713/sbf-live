---
// src/components/Header.astro
---

<style>
    .bg-gold-shimmer {
        background: linear-gradient(90deg, #997b3a 0%, #b89546 25%, #D4AF37 50%, #b89546 75%, #997b3a 100%);
        background-size: 200% auto; 
        animation: subtleShimmer 8s linear infinite;
    }
    @keyframes subtleShimmer { 
        0% { background-position: 0% 50%; } 
        100% { background-position: 100% 50%; } 
    }
    .nav-dropdown {
        opacity: 0; visibility: hidden; transform: translateY(10px); transition: all 0.3s ease-in-out;
    }
    .group:hover .nav-dropdown {
        opacity: 1; visibility: visible; transform: translateY(0);
    }
    .mobile-accordion-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out; }
    .mobile-accordion-btn.active + .mobile-accordion-content { max-height: 300px; }
    .mobile-accordion-btn.active i { transform: rotate(180deg); }
</style>

<!-- Announcement Bar -->
<div class="bg-gold-shimmer text-sb-black text-[10px] py-2.5 px-4 text-center tracking-[0.25em] uppercase font-bold border-b border-sb-cream/20">
    <p>Family Run • Free delivery over £60 within 3 miles • UK Standard £4.99</p>
</div>

<!-- Header -->
<header class="sticky top-0 z-50 bg-sb-black/95 backdrop-blur-md border-b border-white/5" id="mainHeader">
    <div class="container mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-[1fr_auto_1fr] items-center h-20 md:h-24">
            
            <!-- Left Side: Mobile Toggle + Desktop HOME/SHOP -->
            <div class="flex items-center space-x-8">
                <button id="mobileMenuBtn" class="lg:hidden text-xl text-sb-cream p-2 -ml-2">
                    <i class="fas fa-bars"></i>
                </button>
                <nav class="hidden lg:flex items-center space-x-10 text-[11px] tracking-luxury text-gray-300 uppercase font-bold">
                    <a href="/" class="hover:text-sb-gold transition-colors">Home</a>
                    <div class="relative group h-full flex items-center">
                        <button class="uppercase tracking-luxury flex items-center gap-1.5 hover:text-sb-gold transition-colors">
                            Shop <i class="fas fa-chevron-down text-[8px] opacity-50"></i>
                        </button>
                        <div class="nav-dropdown absolute top-full left-0 w-48 bg-sb-black border border-white/10 py-2 shadow-2xl">
                            <a href="/collections/signature" class="block px-6 py-3 hover:text-sb-gold text-[10px] transition-colors">Signature</a>
                            <a href="/collections/seasonal" class="block px-6 py-3 hover:text-sb-gold text-[10px] transition-colors">Seasonal</a>
                            <a href="/collections/sympathy" class="block px-6 py-3 hover:text-sb-gold text-[10px] transition-colors">Sympathy</a>
                        </div>
                    </div>
                </nav>
            </div>

            <!-- Center: Logo -->
            <div class="flex justify-center px-4">
                <a href="/" class="block">
                    <img src="/images/logo.png" alt="SB Floristry" class="h-12 md:h-16 w-auto object-contain">
                </a>
            </div>

            <!-- Right Side: Desktop STORY/CONTACT + Cart -->
            <div class="flex items-center justify-end">
                <nav class="hidden lg:flex items-center space-x-10 text-[11px] tracking-luxury text-gray-300 uppercase font-bold mr-10">
                    <a href="/#our-story" class="hover:text-sb-gold transition-colors">Our Story</a>
                    <a href="/contact" class="hover:text-sb-gold transition-colors">Contact</a>
                </nav>
                <button id="cartBtn" class="relative text-sb-cream hover:text-sb-gold transition-colors p-1">
                    <i class="fas fa-shopping-bag text-sm"></i>
                    <span id="cartCount" class="absolute -top-2 -right-2 bg-sb-black text-sb-gold text-[10px] border border-sb-gold rounded-full w-4 h-4 flex items-center justify-center hidden">0</span>
                </button>
            </div>
        </div>
    </div>
</header>

<!-- Mobile Menu Drawer -->
<div id="mobileMenu" class="fixed inset-0 bg-sb-black z-[100] transform -translate-x-full transition-transform duration-500 lg:hidden flex flex-col pt-20 px-8">
    <button id="closeMenuBtn" class="absolute top-6 right-6 text-2xl text-sb-cream hover:text-sb-gold transition-colors"><i class="fas fa-times"></i></button>
    <nav class="flex flex-col space-y-2">
        <a href="/" class="text-sb-gold text-sm tracking-widest uppercase py-4 border-b border-white/5 mobile-link">Home</a>
        <div>
            <button class="mobile-accordion-btn w-full flex justify-between items-center text-sb-gold text-sm tracking-widest uppercase py-4 border-b border-white/5">
                Shop Collections <i class="fas fa-chevron-down text-xs transition-transform"></i>
            </button>
            <div class="mobile-accordion-content bg-white/5">
                <a href="/collections/signature" class="block py-4 pl-4 text-xs text-gray-300 mobile-link">Signature Collection</a>
                <a href="/collections/seasonal" class="block py-4 pl-4 text-xs text-gray-300 mobile-link">Seasonal Edit</a>
                <a href="/collections/sympathy" class="block py-4 pl-4 text-xs text-gray-300 mobile-link">Sympathy</a>
            </div>
        </div>
        <a href="/#our-story" class="text-sb-gold text-sm tracking-widest uppercase py-4 border-b border-white/5 mobile-link">Our Story</a>
        <a href="/contact" class="text-sb-gold text-sm tracking-widest uppercase py-4 border-b border-white/5 mobile-link">Contact</a>
    </nav>
</div>

<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        const btn = document.getElementById('mobileMenuBtn');
        const close = document.getElementById('closeMenuBtn');
        const menu = document.getElementById('mobileMenu');
        const accs = document.querySelectorAll('.mobile-accordion-btn');
        const links = document.querySelectorAll('.mobile-link');

        const toggle = () => {
            menu.classList.toggle('-translate-x-full');
            document.body.style.overflow = menu.classList.contains('-translate-x-full') ? '' : 'hidden';
        };

        btn?.addEventListener('click', toggle);
        close?.addEventListener('click', toggle);
        links.forEach(l => l.addEventListener('click', () => {
            menu.classList.add('-translate-x-full');
            document.body.style.overflow = '';
        }));
        accs.forEach(a => a.addEventListener('click', function() { this.classList.toggle('active'); }));
    });
</script>