---
// src/components/CartModal.astro
---

<!-- Overlay -->
<div id="cartOverlay" class="fixed inset-0 bg-sb-black/60 backdrop-blur-sm z-50 hidden opacity-0 transition-opacity duration-300"></div>

<!-- Sidebar -->
<div id="cartSidebar" class="fixed top-0 right-0 h-full w-full sm:w-[400px] bg-sb-cream shadow-2xl z-50 transform translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.19,1,0.22,1)] flex flex-col">
    <!-- Header -->
    <div class="px-6 py-8 border-b border-gray-200 flex justify-between items-center bg-white">
        <h3 class="font-serif text-2xl text-sb-black">Your Cart</h3>
        <button id="closeCartBtn" class="text-gray-400 hover:text-sb-gold transition-colors p-2">
            <i class="fas fa-times text-xl"></i>
        </button>
    </div>

    <!-- Cart Items Container (JavaScript will populate this) -->
    <div id="cartItemsContainer" class="flex-grow overflow-y-auto p-6 space-y-6">
        <!-- Empty state default -->
        <div class="text-center text-gray-500 mt-10 font-serif italic" id="emptyCartMessage">
            Your cart is currently empty.
        </div>
    </div>

    <!-- Footer / Checkout -->
    <div class="border-t border-gray-200 p-6 bg-white">
        <div class="flex justify-between mb-4 font-serif text-lg">
            <span class="text-gray-600">Subtotal</span>
            <span class="text-sb-black" id="cartSubtotal">£0.00</span>
        </div>
        <p class="text-xs text-gray-500 mb-6 font-light">Taxes and delivery calculated at checkout.</p>
        <button id="checkoutBtn" class="w-full bg-sb-black text-white py-4 font-bold tracking-[0.2em] text-[10px] uppercase hover:bg-sb-gold transition-colors">
            Proceed to Checkout
        </button>
    </div>
</div>