---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Our Story" 
  description="Discover the mother and daughter floral studio behind SB Floristry."
>
  <section class="py-24 bg-white relative">
    <div class="container mx-auto px-6">
      <div class="text-center mb-16 reveal">
          <span class="text-sb-gold text-xs tracking-[0.35em] uppercase font-bold mb-4 block">The Studio</span>
          <h2 class="font-serif text-5xl md:text-6xl text-sb-black mb-6">A Mother & Daughter Story</h2>
          <div class="w-16 h-px bg-sb-gold mx-auto mb-10"></div>
      </div>
      
      <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-24 mb-24 reveal">
        <div class="w-full lg:w-1/2 relative group">
          <div class="absolute -inset-4 border border-sb-gold/30 translate-x-4 translate-y-4 -z-10 transition-transform duration-500 group-hover:translate-x-2 group-hover:translate-y-2"></div>
          <img src="/images/story-mother-daughter.jpg" alt="Mother and Daughter Florists" class="w-full h-auto object-cover shadow-xl grayscale-[20%] hover:grayscale-0 transition-all duration-700" />
        </div>
        <div class="w-full lg:w-1/2">
          <h3 class="font-serif text-3xl md:text-4xl text-sb-black mb-6">Family at the Heart</h3>
          <p class="text-gray-600 mb-6 font-light leading-relaxed text-lg">
            Welcome to SB Floristry. We are a family-run floral design studio driven by a shared passion for creating unforgettable arrangements. What started as a lifelong love for flowers has blossomed into a dedicated partnership.
          </p>
          <p class="text-gray-600 mb-8 font-light leading-relaxed text-lg">
            Every bouquet we create is a reflection of our bond—combining timeless, traditional techniques with contemporary design. We believe that flowers are more than just decoration; they are the heart of life's most meaningful moments.
          </p>
          <img src="/images/logo.png" alt="Signature" class="h-12 opacity-80 mix-blend-multiply" />
        </div>
      </div>
    </div>
  </section>
  
  <section class="py-24 bg-sb-black text-sb-cream relative border-t border-white/5">
      <div class="container mx-auto px-6 text-center max-w-2xl">
          <span class="text-gold-metallic text-2xl mb-6 block reveal"><i class="fas fa-leaf"></i></span>
          <h2 class="font-serif text-4xl md:text-5xl text-sb-cream mb-8 reveal font-light">Essex & London</h2>
          <p class="text-gray-400 leading-relaxed text-xl font-light mb-12 reveal">
              We bring bespoke, luxury floral design to weddings, events, and homes across Essex and London. Every arrangement is hand-selected and styled with the care only family can provide.
          </p>
          <div class="flex flex-col md:flex-row justify-center gap-12 text-xs font-bold tracking-luxury text-sb-cream uppercase reveal">
              <div class="flex items-center justify-center"><i class="fas fa-truck mr-3 text-sb-gold"></i> Free Local Delivery</div>
              <div class="flex items-center justify-center"><i class="fas fa-heart mr-3 text-sb-gold"></i> Hand-Tied with Love</div>
          </div>
      </div>
  </section>
</Layout>
