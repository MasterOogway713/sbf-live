---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Our Story | Luxury London & Essex Florists | SB Floristry" 
  description="Meet the mother and daughter team behind SB Floristry. Discover our passion for luxury floral design, our family heritage, and our commitment to botanical artistry."
>
  <!-- SEO Structured Data -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "AboutPage",
      "mainEntity": {
        "@type": "LocalBusiness",
        "name": "SB Floristry",
        "description": "A luxury mother and daughter floral design studio based in Essex, delivering to London.",
        "image": "https://www.sbfloristry.co.uk/images/story-mother-daughter.jpg"
      }
    }
  </script>

  <!-- Editorial Header -->
  <section class="pt-40 pb-20 bg-sb-cream text-center relative overflow-hidden">
    <div class="container mx-auto px-6 relative z-10 reveal">
        <span class="text-sb-gold text-xs tracking-[0.35em] uppercase font-bold mb-6 block">Heritage & Craft</span>
        <h1 class="font-serif text-6xl md:text-8xl text-sb-black mb-6 font-light">Our Story</h1>
        <div class="w-16 h-px bg-sb-gold mx-auto mb-10"></div>
        <p class="text-xl font-light italic max-w-2xl mx-auto text-gray-500">
          Rooted in family, blooming with passion.
        </p>
    </div>
  </section>
  
  <!-- Content Section 1: The Studio & The Bond -->
  <section class="py-24 bg-sb-cream relative">
    <div class="container mx-auto px-6">
      <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-24 mb-32 reveal">
        <div class="w-full lg:w-1/2 relative group">
          <!-- Decorative Frame -->
          <div class="absolute -inset-4 border border-sb-gold/30 translate-x-4 translate-y-4 -z-10 transition-transform duration-500 group-hover:translate-x-2 group-hover:translate-y-2"></div>
          <img src="/images/story-mother-daughter.jpg" alt="Mother and Daughter Florists in Studio" class="w-full h-auto object-cover shadow-2xl grayscale-[20%] hover:grayscale-0 transition-all duration-700" />
        </div>
        <div class="w-full lg:w-1/2">
          <span class="text-sb-gold text-xs tracking-luxury uppercase font-bold mb-4 block">The Founders</span>
          <h2 class="font-serif text-4xl md:text-5xl text-sb-black mb-8 font-light">A Mother & Daughter Bond</h2>
          <p class="text-gray-600 mb-6 font-light leading-relaxed text-lg">
            Welcome to SB Floristry. We are a boutique floral design studio driven by a shared, lifelong passion for the natural world. What began years ago as a deep appreciation for garden blooms has blossomed into a dedicated, professional partnership between mother and daughter.
          </p>
          <p class="text-gray-600 mb-8 font-light leading-relaxed text-lg">
            Working side-by-side every day, our unique dynamic allows us to blend timeless, traditional floristry techniques with fresh, contemporary design aesthetics. We understand each other intuitively, which translates into seamless execution and deeply personal care for every client we serve.
          </p>
          <img src="/images/logo.png" alt="SB Floristry Signature" class="h-16 opacity-70 mix-blend-multiply" />
        </div>
      </div>
    </div>
  </section>

  <!-- Content Section 2: The Craft -->
  <section class="py-24 bg-white relative">
    <div class="container mx-auto px-6">
      <div class="flex flex-col lg:flex-row-reverse items-center gap-16 lg:gap-24 reveal">
        <div class="w-full lg:w-1/2 relative group">
          <div class="absolute -inset-4 bg-[#f2f0eb] -translate-x-4 -translate-y-4 -z-10 transition-transform duration-500 group-hover:-translate-x-2 group-hover:-translate-y-2"></div>
          <img src="/images/story-arranging.jpg" alt="Hands arranging white roses" class="w-full h-auto object-cover shadow-xl transition-all duration-700" />
        </div>
        <div class="w-full lg:w-1/2">
          <span class="text-sb-gold text-xs tracking-luxury uppercase font-bold mb-4 block">Our Philosophy</span>
          <h2 class="font-serif text-4xl md:text-5xl text-sb-black mb-8 font-light">Artistry in Every Stem</h2>
          <p class="text-gray-600 mb-6 font-light leading-relaxed text-lg">
            We believe that flowers are far more than mere decoration; they are the emotional heartbeat of life's most meaningful moments. Whether crafting an intimate bridal bouquet, a grand venue installation, or a delicate sympathy tribute, we source only the most exquisite, premium stems.
          </p>
          <p class="text-gray-600 mb-8 font-light leading-relaxed text-lg">
            Every arrangement that leaves our Romford studio is meticulously inspected by both of us. It is this unwavering commitment to perfection, quality, and personalized luxury that has defined our reputation across Essex and London.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Full Width Image Break -->
  <section class="py-20 bg-sb-cream reveal">
      <div class="container mx-auto px-6">
          <div class="w-full h-[50vh] overflow-hidden relative">
              <img src="/images/gallery-6.jpg" alt="SB Floristry Shop Sign" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-[2s]">
          </div>
      </div>
  </section>
  
  <!-- Final Promise / CTA -->
  <section class="py-32 bg-sb-black text-sb-cream relative border-t border-white/5">
      <div class="container mx-auto px-6 text-center max-w-3xl">
          <span class="text-gold-metallic text-3xl mb-8 block reveal"><i class="fas fa-leaf"></i></span>
          <h2 class="font-serif text-4xl md:text-5xl text-sb-cream mb-8 reveal font-light">Our Promise</h2>
          <p class="text-gray-400 leading-relaxed text-xl font-light mb-12 reveal">
              When you choose SB Floristry, you are not just ordering flowers; you are trusting a family to tell your story. From our hands to yours, we promise unparalleled luxury, dedication, and beauty.
          </p>
          <div class="reveal">
              <a href="/contact" class="btn-luxury border border-sb-gold text-sb-cream px-12 py-4 uppercase tracking-luxury text-xs font-bold inline-block hover:text-sb-black">
                  Work With Us
              </a>
          </div>
      </div>
  </section>
</Layout>
