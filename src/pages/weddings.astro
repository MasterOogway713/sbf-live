---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Luxury Wedding Florist in Essex & London | SB Floristry" 
  description="Bespoke luxury wedding floristry across Essex and London. From intimate bridal bouquets to breathtaking venue installations, let us tell your love story in bloom."
>
  <!-- SEO Structured Data -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Wedding Floristry",
      "provider": {
        "@type": "LocalBusiness",
        "name": "SB Floristry",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Romford",
          "addressRegion": "Essex",
          "addressCountry": "UK"
        }
      },
      "areaServed": ["Essex", "London"],
      "description": "Bespoke luxury wedding flowers, bridal bouquets, and venue installations."
    }
  </script>

  <!-- Hero Section -->
  <section class="relative h-[85vh] overflow-hidden bg-sb-black">
      <div class="absolute inset-0">
          <img src="/images/weddings-bg.jpg" alt="Luxury Wedding Floral Setup" class="w-full h-full object-cover hero-zoom opacity-80" style="object-position: center 70%;">
          <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-sb-cream"></div>
      </div>
      <div class="relative z-10 container mx-auto px-6 h-full flex flex-col justify-center items-center text-center text-sb-cream pt-20">
          <span class="text-sb-gold text-[10px] md:text-xs tracking-[0.35em] uppercase font-bold mb-6 reveal">Bespoke Bridal Design</span>
          <h1 class="font-serif text-6xl md:text-8xl lg:text-9xl mb-8 font-light reveal text-shadow-sm">Weddings</h1>
          <p class="text-lg md:text-xl font-light italic max-w-2xl mx-auto reveal tracking-wide opacity-90">
            Crafting unforgettable atmospheres for your most treasured day.
          </p>
      </div>
  </section>
  
  <!-- Introduction -->
  <section class="py-24 lg:py-32 bg-sb-cream text-sb-black transition-colors duration-500">
      <div class="container mx-auto px-6 max-w-4xl text-center">
          <h2 class="font-serif text-4xl lg:text-5xl mb-8 font-light italic reveal">Your Love Story, In Bloom</h2>
          <p class="text-xl text-gray-600 font-light leading-relaxed mb-12 reveal drop-cap">
              <span class="text-5xl font-serif float-left mr-3 text-sb-gold mt-1">F</span>rom charming Essex countryside estates to glamorous London ballroom celebrations, we design with absolute heart and meticulous precision. We believe your wedding flowers should be as unique and profound as your relationship, setting a breathtaking tone for a day you will never forget.
          </p>
          <div class="w-24 h-px bg-sb-gold mx-auto reveal"></div>
      </div>
  </section>

  <!-- Editorial Services Layout -->
  <section class="py-12 bg-sb-cream overflow-hidden">
      <div class="container mx-auto px-6">
          
          <!-- Bridal Party (Image Left, Text Right) -->
          <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-24 mb-32 reveal">
              <div class="w-full lg:w-1/2 relative group">
                  <div class="absolute inset-0 bg-sb-gold/10 translate-x-4 translate-y-4 -z-10 transition-transform duration-500 group-hover:translate-x-6 group-hover:translate-y-6"></div>
                  <img src="/images/product-pure-elegance.jpg" alt="Bridal Bouquets" class="w-full h-[600px] object-cover grayscale-[10%] hover:grayscale-0 transition-all duration-700">
              </div>
              <div class="w-full lg:w-1/2 lg:pr-12">
                  <span class="text-sb-gold text-xs tracking-luxury uppercase font-bold mb-4 block">01. The Personal Details</span>
                  <h3 class="font-serif text-4xl text-sb-black mb-6">The Bridal Party</h3>
                  <p class="text-gray-600 leading-relaxed font-light text-lg mb-8">
                      The bouquet is the ultimate bridal accessory. From cascading traditional teardrops to wild, asymmetrical modern gatherings, we hand-select the finest stems to perfectly complement your gown. We extend this meticulous attention to detail to bridesmaids' posies, delicate flower crowns, and tailored buttonholes.
                  </p>
              </div>
          </div>

          <!-- Ceremony (Text Left, Image Right) -->
          <div class="flex flex-col lg:flex-row-reverse items-center gap-12 lg:gap-24 mb-32 reveal">
              <div class="w-full lg:w-1/2 relative group">
                  <div class="absolute inset-0 bg-sb-black/5 -translate-x-4 translate-y-4 -z-10 transition-transform duration-500 group-hover:-translate-x-6 group-hover:translate-y-6"></div>
                  <img src="/images/collection-weddings.jpg" alt="Wedding Ceremony Archway" class="w-full h-[600px] object-cover grayscale-[10%] hover:grayscale-0 transition-all duration-700">
              </div>
              <div class="w-full lg:w-1/2 lg:pl-12">
                  <span class="text-sb-gold text-xs tracking-luxury uppercase font-bold mb-4 block">02. The Vows</span>
                  <h3 class="font-serif text-4xl text-sb-black mb-6">The Ceremony</h3>
                  <p class="text-gray-600 leading-relaxed font-light text-lg mb-8">
                      Frame the moment you say "I do" with breathtaking botanical architecture. Whether you envision a lush, deconstructed floral archway, romantic meadow aisle runners, or elegant urns flanking the altar, we design ceremony spaces that evoke pure romance and reverence.
                  </p>
              </div>
          </div>

          <!-- Reception (Image Left, Text Right) -->
          <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-24 mb-16 reveal">
              <div class="w-full lg:w-1/2 relative group">
                  <div class="absolute inset-0 bg-sb-gold/10 translate-x-4 -translate-y-4 -z-10 transition-transform duration-500 group-hover:translate-x-6 group-hover:-translate-y-6"></div>
                  <img src="/images/gallery-5.jpg" alt="Wedding Reception Installation" class="w-full h-[600px] object-cover grayscale-[10%] hover:grayscale-0 transition-all duration-700">
              </div>
              <div class="w-full lg:w-1/2 lg:pr-12">
                  <span class="text-sb-gold text-xs tracking-luxury uppercase font-bold mb-4 block">03. The Celebration</span>
                  <h3 class="font-serif text-4xl text-sb-black mb-6">The Reception</h3>
                  <p class="text-gray-600 leading-relaxed font-light text-lg mb-8">
                      Transform your venue into a mesmerizing landscape. We specialize in dramatic hanging installations, abundant tablescapes, and focal point bar designs that leave a lasting impression on your guests. Every element is styled on-site by our expert team to ensure flawless execution.
                  </p>
              </div>
          </div>

      </div>
  </section>

  <!-- CTA Section -->
  <section class="py-32 bg-sb-black text-sb-cream text-center relative border-t border-white/10">
      <div class="container mx-auto px-6 max-w-3xl reveal">
          <h2 class="font-serif text-5xl mb-6 font-light">Begin Your Journey</h2>
          <p class="text-gray-400 text-lg font-light mb-12">
              We take on a limited number of weddings each year to ensure our couples receive our undivided attention. Contact us to arrange a private consultation.
          </p>
          <a href="/contact" class="btn-luxury border border-sb-gold text-sb-cream px-12 py-4 uppercase tracking-luxury text-xs font-bold inline-block hover:text-sb-black">
              Request a Consultation
          </a>
      </div>
  </section>
</Layout>

<style>
  .drop-cap span {
    line-height: 0.8;
  }
  .text-shadow-sm {
    text-shadow: 2px 4px 10px rgba(0,0,0,0.3);
  }
</style>
