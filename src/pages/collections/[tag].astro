---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { shopifyFetch } from '../../utils/shopify.js';

export async function getStaticPaths() {
  const tagsQuery = `
    {
      products(first: 250) {
        edges { node { tags } }
      }
    }
  `;
  
  const response = await shopifyFetch({ query: tagsQuery });
  const products = response?.data?.products?.edges || [];
  
  const allTags = new Set();
  const ignoredTags = ['subscription', 'bespoke', 'add-on', 'upsell', 'white', 'red', 'pink'];
  
  products.forEach((edge) => {
    edge.node.tags.forEach((tag) => {
      const cleanTag = tag.trim().toLowerCase();
      if (!ignoredTags.includes(cleanTag)) {
        allTags.add(cleanTag.replace(/\s+/g, '-')); 
      }
    });
  });

  // Fallback routes in case build runs before products are tagged
  if (allTags.size === 0) {
    allTags.add('seasonal');
    allTags.add('signature');
  }

  return Array.from(allTags).map((tag) => ({
    params: { tag }
  }));
}

const { tag } = Astro.params;
const displayTitle = tag.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');

// Dark Theme logic imported directly from your original index.html JS
const isDark = tag.includes('gothic') || tag.includes('dark') || tag.includes('halloween');

const productsQuery = `
  {
    products(first: 20, query: "tag:${tag.replace(/-/g, ' ')}") {
      edges {
        node {
          id
          title
          handle
          description
          images(first: 2) { edges { node { url altText } } }
          variants(first: 1) { edges { node { id price { amount currencyCode } } } }
        }
      }
    }
  }
`;

const productsResponse = await shopifyFetch({ query: productsQuery });
const collectionProducts = productsResponse?.data?.products?.edges || [];
---

<Layout title={`${displayTitle} Collection | SB Floristry`} description={`Shop our ${displayTitle} collection.`}>
  <section class={`pt-40 pb-20 text-center transition-colors duration-500 ${isDark ? 'bg-sb-black text-sb-cream' : 'bg-sb-cream text-sb-black'}`}>
    <span class="text-sb-gold text-xs tracking-[0.35em] uppercase font-bold mb-4 block">The Collection</span>
    <h1 class={`font-serif text-6xl md:text-8xl mb-6 font-light ${isDark ? 'text-sb-cream' : 'text-sb-black'}`}>
      {displayTitle}
    </h1>
    <p class={`text-xl font-light italic max-w-2xl mx-auto ${isDark ? 'text-gray-400' : 'text-gray-500'}`}>
      The {displayTitle} Collection
    </p>
  </section>

  <section class={`pb-24 transition-colors duration-500 ${isDark ? 'bg-sb-black' : 'bg-sb-cream'}`}>
    <div class="container mx-auto px-6">
      {collectionProducts.length === 0 ? (
        <div class="col-span-full text-center py-12">
          <p class={`text-xl font-serif mb-2 ${isDark ? 'text-gray-400' : 'text-gray-500'}`}>No products found.</p>
          <p class="text-sm text-gray-400">We couldn't find any products tagged with <strong>#{tag}</strong>.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-12 min-h-[400px]">
          {collectionProducts.map((edge) => (
             <ProductCard product={edge.node} isDark={isDark} />
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
