---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { shopifyFetch } from '../../utils/shopify.js';

export async function getStaticPaths() {
  const tagsQuery = `
    {
      products(first: 250) {
        edges { node { tags } }
      }
    }
  `;
  
  const response = await shopifyFetch({ query: tagsQuery });
  const products = response?.data?.products?.edges || [];
  
  const allTags = new Set();
  const ignoredTags = ['subscription', 'bespoke', 'add-on', 'upsell', 'white', 'red', 'pink'];
  
  products.forEach((edge) => {
    edge.node.tags.forEach((tag) => {
      const cleanTag = tag.trim().toLowerCase();
      if (!ignoredTags.includes(cleanTag)) {
        allTags.add(cleanTag.replace(/\s+/g, '-')); 
      }
    });
  });

  // Fallback routes in case build runs before products are tagged
  if (allTags.size === 0) {
    allTags.add('seasonal');
    allTags.add('signature');
  }

  return Array.from(allTags).map((tag) => ({
    params: { tag }
  }));
}

const { tag } = Astro.params;
const displayTitle = tag.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');

// Dark Theme logic
const isDark = tag.includes('gothic') || tag.includes('dark') || tag.includes('halloween');

// 1. Dynamic Content Mapper for SEO and Aesthetics
// Expanded with richer, distinct descriptions for various potential collections
const collectionData = {
  'seasonal': {
    description: "Embrace the changing of the guard. Our Seasonal Edit captures the fleeting beauty of nature's current offerings, featuring the freshest, most vibrant blooms sourced directly for their peak perfection.",
    image: "/images/collection-seasonal.jpg"
  },
  'signature': {
    description: "The epitome of SB Floristry. Timeless, elegant, and breathtakingly luxurious. Our Signature Collection features our most sought-after, classic arrangements designed to leave a lasting impression.",
    image: "/images/collection-signature.jpg"
  },
  'weddings': {
    description: "Romantic, abundant, and utterly bespoke. A curated selection of our finest wedding-inspired arrangements, from delicate bridal touches to grand romantic gestures.",
    image: "/images/collection-weddings.jpg"
  },
  'sympathy': {
    description: "Thoughtful, gentle, and respectful arrangements crafted to convey your deepest condolences. Using calming palettes and premium stems to honor loved ones with grace.",
    image: "/images/collection-sympathy.jpg"
  },
  'gothic': {
    description: "Moody, dramatic, and unapologetically bold. The Gothic Edit features deep, velvety hues, striking silhouettes, and rich textures for those who find exquisite beauty in the shadows.",
    image: "/images/gallery-1.jpg"
  },
  'luxury': {
    description: "Uncompromising opulence. Our Luxury Collection showcases the rarest stems and most extravagant, voluminous designs, curated strictly for moments that demand absolute perfection.",
    image: "/images/hero.jpg"
  },
  'fairytale': {
    description: "Ethereal, soft, and deeply romantic. Step into a world of whimsical pastels, trailing foliage, and enchanting blooms straight out of a storybook.",
    image: "/images/product-pure-elegance.jpg"
  }
};

// Fallback for dynamically generated tags that aren't in the explicit list above
const currentCollection = collectionData[tag.toLowerCase()] || { 
  description: `Discover the art of gifting with our exclusive ${displayTitle} collection. Hand-tied by our expert florists in Essex and delivered with uncompromising care.`, 
  image: "/images/gallery-3.jpg" 
};

const productsQuery = `
  {
    products(first: 20, query: "tag:${tag.replace(/-/g, ' ')}") {
      edges {
        node {
          id
          title
          handle
          description
          images(first: 2) { edges { node { url altText } } }
          variants(first: 1) { edges { node { id price { amount currencyCode } } } }
        }
      }
    }
  }
`;

const productsResponse = await shopifyFetch({ query: productsQuery });
const collectionProducts = productsResponse?.data?.products?.edges || [];
const productCount = collectionProducts.length;
---

<Layout title={`${displayTitle} Collection | Luxury Essex Florist | SB Floristry`} description={currentCollection.description}>
  
  <!-- SEO Structured Data: CollectionPage -->
  <script type="application/ld+json" is:inline set:html={`
    {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": "${displayTitle} Collection - SB Floristry",
      "description": "${currentCollection.description}",
      "url": "https://www.sbfloristry.co.uk/collections/${tag}",
      "numberOfItems": ${productCount}
    }
  `} />

  <!-- Hero Banner with Background Image -->
  <section class="relative h-[60vh] overflow-hidden bg-sb-black flex flex-col justify-end">
    <div class="absolute inset-0">
      <img src={currentCollection.image} alt={`${displayTitle} Collection`} class="w-full h-full object-cover opacity-70 scale-105" style="object-position: center 40%;">
      <div class="absolute inset-0 bg-gradient-to-t from-sb-black via-black/40 to-transparent"></div>
    </div>
    
    <div class="relative z-10 container mx-auto px-6 pb-16 text-center text-sb-cream">
      <!-- Breadcrumbs -->
      <nav class="text-[10px] tracking-luxury uppercase font-bold text-gray-300 mb-6 flex justify-center items-center space-x-2 reveal">
        <a href="/" class="hover:text-sb-gold transition-colors">Home</a>
        <span class="text-gray-500">/</span>
        <span class="text-gray-500">Collections</span>
        <span class="text-gray-500">/</span>
        <span class="text-sb-gold">{displayTitle}</span>
      </nav>
      
      <h1 class="font-serif text-6xl md:text-8xl mb-6 font-light reveal">{displayTitle}</h1>
      <p class="text-lg md:text-xl font-light italic max-w-2xl mx-auto text-gray-300 reveal drop-shadow-md">
        {currentCollection.description}
      </p>
    </div>
  </section>

  <!-- Collection Grid Area -->
  <section class={`py-16 transition-colors duration-500 ${isDark ? 'bg-sb-black text-sb-cream' : 'bg-sb-cream text-sb-black'}`}>
    <div class="container mx-auto px-6">
      
      <!-- Utility Bar (Product Count & Sort Filter) -->
      <div class={`flex justify-between items-center pb-6 mb-12 border-b ${isDark ? 'border-white/10' : 'border-gray-200'} reveal`}>
        <span class="text-[10px] tracking-luxury uppercase font-bold text-gray-500">
          Showing {productCount} {productCount === 1 ? 'Arrangement' : 'Arrangements'}
        </span>
        
        <!-- Functional Sort Dropdown -->
        <div class="relative group flex items-center">
          <label for="sortSelect" class="text-[10px] tracking-luxury uppercase font-bold text-gray-500 mr-2 hidden sm:block">Sort By:</label>
          <div class="relative">
            <select id="sortSelect" class={`appearance-none bg-transparent text-[10px] tracking-luxury uppercase font-bold cursor-pointer outline-none transition-colors pr-6 focus:text-sb-gold ${isDark ? 'text-sb-cream' : 'text-sb-black'}`}>
              <option value="featured" class="bg-sb-black text-sb-cream">Featured</option>
              <option value="price-asc" class="bg-sb-black text-sb-cream">Price: Low to High</option>
              <option value="price-desc" class="bg-sb-black text-sb-cream">Price: High to Low</option>
              <option value="title-asc" class="bg-sb-black text-sb-cream">Alphabetically: A-Z</option>
            </select>
            <i class="fas fa-chevron-down absolute right-0 top-1/2 -translate-y-1/2 text-[8px] pointer-events-none text-sb-gold"></i>
          </div>
        </div>
      </div>

      <!-- Products -->
      {productCount === 0 ? (
        <div class="col-span-full text-center py-24">
          <i class="fas fa-seedling text-sb-gold text-4xl mb-6 opacity-50"></i>
          <p class={`text-2xl font-serif mb-2 font-light ${isDark ? 'text-gray-300' : 'text-gray-600'}`}>We are currently arranging new blooms.</p>
          <p class={`text-sm font-light ${isDark ? 'text-gray-400' : 'text-gray-500'}`}>Check back shortly for our updated <strong>{displayTitle}</strong> collection.</p>
          <a href="/" class="inline-block mt-8 text-[10px] uppercase tracking-luxury font-bold border-b border-sb-gold text-sb-gold pb-1 hover:text-sb-black hover:border-sb-black transition-colors">Return to Home</a>
        </div>
      ) : (
        <div id="productGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16 min-h-[400px]">
          {collectionProducts.map((edge) => {
            const price = edge.node.variants?.edges[0]?.node?.price?.amount || 0;
            const title = edge.node.title || '';
            return (
              // The wrapper holds the data attributes needed for our sorting script
              <div class="sortable-item" data-price={price} data-title={title}>
                 <ProductCard product={edge.node} isDark={isDark} />
              </div>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <!-- Client-Side Sorting Script -->
  <script is:inline>
    document.addEventListener('astro:page-load', () => {
      const sortSelect = document.getElementById('sortSelect');
      const productGrid = document.getElementById('productGrid');
      
      if (!sortSelect || !productGrid) return;

      // Cache the original DOM nodes order to restore the "Featured" default
      const originalOrder = Array.from(productGrid.children);

      sortSelect.addEventListener('change', (e) => {
        const sortBy = e.target.value;
        const items = Array.from(productGrid.children);

        if (sortBy === 'featured') {
          originalOrder.forEach(item => productGrid.appendChild(item));
          return;
        }

        items.sort((a, b) => {
          if (sortBy === 'price-asc' || sortBy === 'price-desc') {
            const priceA = parseFloat(a.dataset.price);
            const priceB = parseFloat(b.dataset.price);
            return sortBy === 'price-asc' ? priceA - priceB : priceB - priceA;
          } else if (sortBy === 'title-asc') {
            const titleA = a.dataset.title.toLowerCase();
            const titleB = b.dataset.title.toLowerCase();
            return titleA.localeCompare(titleB);
          }
          return 0;
        });

        // Re-append the items in their newly sorted order
        items.forEach(item => productGrid.appendChild(item));
      });
    });
  </script>
</Layout>
